OPENROUTER_API_KEY=sk-or-v1-...

PORT=3000

# Environment tag — used by /admin/budget to split dev vs prod usage.
# Set to "prod" on the VPS deploy; default is "dev".
MIRROR_ENV=dev

# Base URL the mirror is reachable at — sent as HTTP-Referer on OpenRouter
# calls so the provider's dashboard can group traffic per install. Optional
# (defaults to http://localhost:3000).
MIRROR_BASE_URL=http://localhost:3000

# Telegram (optional — leave empty to disable the adapter)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
