OPENROUTER_API_KEY=sk-or-v1-...

# LLM model (any OpenRouter-compatible model).
# Recommended: deepseek/deepseek-chat-v3-0324 (good quality/cost, follows identity prompts well)
# Alternatives: anthropic/claude-sonnet-4, google/gemini-2.0-flash-001
LLM_MODEL=deepseek/deepseek-chat-v3-0324

PORT=3000

# Telegram (optional — leave empty to disable the adapter)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
